# Maintainer: vendi <layoguerrero@gmail.com>
pkgname=vendimessage
pkgver=0.0.1
pkgrel=1
pkgdesc="Private, iMessage-inspired messenger for vendiOS (Matrix-backed, walled-garden)"
arch=('x86_64')
url="https://github.com/VendavalSC/vendiOS"
license=('MIT')
depends=('qt6-declarative' 'qt6-quickcontrols2' 'qt6-websockets' 'gcc-libs')
optdepends=('adwaita-fonts: default UI font (Adwaita Sans)')
makedepends=('rust' 'cargo')
install="$pkgname.install"
# Sourced from the vendiOS monorepo release tag. After you push the v$pkgver tag
# to GitHub, run `updpkgsums` to replace SKIP with the real checksum.
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

_src="vendiOS-$pkgver"

prepare() {
  cd "$_src/src"
  export CARGO_TARGET_DIR=target
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "$_src/src"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  # the messenger daemon needs the real Matrix backend
  cargo build --release --frozen --features matrix -p vendi-chatd
}

package() {
  cd "$_src"

  # backend daemon
  install -Dm755 "src/target/release/vendi-chatd" "$pkgdir/usr/bin/vendi-chatd"

  # GUI launcher
  install -Dm755 "packaging/vendimessage" "$pkgdir/usr/bin/vendimessage"

  # QML application
  install -Dm644 -t "$pkgdir/usr/share/vendimessage/qml" apps/vendimessage/qml/*.qml
  install -Dm644 -t "$pkgdir/usr/share/vendimessage/qml" apps/vendimessage/qml/*.js

  # desktop entry + systemd user service
  install -Dm644 "packaging/vendimessage.desktop" "$pkgdir/usr/share/applications/vendimessage.desktop"
  install -Dm644 "packaging/vendi-chatd.service"  "$pkgdir/usr/lib/systemd/user/vendi-chatd.service"

  # license + a sample homeserver config
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 /dev/stdin "$pkgdir/usr/share/vendimessage/chat.conf.example" <<'CONF'
# Copy to ~/.config/vendi/chat.conf and set your homeserver.
# vendiMessage signs in / registers against this server (federation off).
homeserver = https://server.emerald-ayu.ts.net
CONF
}
