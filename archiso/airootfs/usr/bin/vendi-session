#!/usr/bin/env bash
# vendi-session — picks and launches the user's compositor, then brings up
# the desktop services (bar, notification daemon, etc.) once the Wayland
# socket is ready.
set -e

VENDI_SESSION=vendiwm
[[ -f /etc/vendi/session.conf ]] && source /etc/vendi/session.conf

# Desktop identity — xdg-desktop-portal matches this against portals.conf to
# pick the wlroots backend (screen-share / screenshot via wlr-screencopy).
export XDG_CURRENT_DESKTOP=vendiwm
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=vendiwm

# Stream the compositor's stderr to a flat log file — easier to inspect
# off-disk than chasing it through greetd's journal.
mkdir -p "${HOME}/logs"
LOG="${HOME}/logs/vendi-session.log"

# Release Plymouth's hold on the GPU so the compositor can become DRM master.
# NOTE: --retain-splash keeps plymouthd alive holding /dev/dri/cardN, which
# makes the compositor's session.open fail with EBUSY on real hardware (e.g.
# Intel i915) even though it works on the VM's virtio GPU. So do a full quit
# and wait until plymouthd has actually exited (and released DRM) before
# handing off — a brief black flash beats a black-screen boot.
plymouth quit 2>/dev/null || true
for _ in $(seq 1 30); do
    pgrep -x plymouthd >/dev/null 2>&1 || break
    sleep 0.1
done

# The exec below turns this shell into the compositor, so $$ is the
# compositor's pid — the bar supervisor watches it to know when to quit.
WM_PID=$$

# Best-effort: wait for the compositor's wayland socket to appear, then bring
# up waybar and friends as siblings inside the same session. Backgrounded so
# the compositor exec below stays in the foreground for greetd.
spawn_desktop() {
    local sock_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    for _ in $(seq 1 60); do
        if compgen -G "${sock_dir}/wayland-*" >/dev/null; then
            break
        fi
        sleep 0.25
    done
    # Pick the first wayland-N that appeared.
    local sock
    sock=$(ls -1 "${sock_dir}"/wayland-* 2>/dev/null | grep -vE '\.lock$' | head -1)
    [[ -n "$sock" ]] || return 0
    export WAYLAND_DISPLAY="$(basename "$sock")"
    # vendiwm binds its IPC socket adjacent to the wayland socket.
    export VENDIWM_SOCK="${sock_dir}/${WAYLAND_DISPLAY}.ipc.sock"
    # Hand the live display to the D-Bus activation env so dbus-activated
    # services (xdg-desktop-portal + the wlr backend) can reach the
    # compositor when an app first asks to screen-share.
    if command -v dbus-update-activation-environment >/dev/null; then
        dbus-update-activation-environment --systemd \
            WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE 2>/dev/null || true
    fi
    # Polkit authentication agent — the GUI password prompt for privileged
    # actions (mounting internal disks, changing system settings, etc.).
    # Without an agent running, those actions just fail with no prompt.
    if [[ -x /usr/lib/polkit-kde-authentication-agent-1 ]] && \
       ! pgrep -f polkit-kde-authentication-agent-1 >/dev/null; then
        /usr/lib/polkit-kde-authentication-agent-1 >>"$LOG" 2>&1 &
    fi
    # Clipboard history: cliphist records every copy (text + images) so the
    # spotlight `v` provider can paste anything from recent history.
    if command -v cliphist >/dev/null; then
        pkill -x wl-paste 2>/dev/null || true
        wl-paste --type text  --watch cliphist store >>"$LOG" 2>&1 &
        wl-paste --type image --watch cliphist store >>"$LOG" 2>&1 &
    fi
    # Security: lock before the machine sleeps (lid close / suspend / hibernate)
    # so it always resumes to the lock screen — never a live desktop. Watches
    # logind's PrepareForSleep(true) signal on the system bus.
    if command -v dbus-monitor >/dev/null; then
        (
            dbus-monitor --system \
                "type='signal',interface='org.freedesktop.login1.Manager',member='PrepareForSleep'" 2>/dev/null \
            | while read -r l; do
                case "$l" in *"boolean true"*) vendi-ctl lock >>"$LOG" 2>&1 || true ;; esac
            done
        ) &
    fi
    # Status bar — ~/.config/vendi/bar picks the flavor:
    #   classic (default)  GTK4 vendibar, minimal macOS-style
    #   pro                quickshell island bar (vendibar-pro)
    # Supervisor loop: re-reads the choice file every spawn, so
    # `vendi bar <classic|pro>` only has to kill the running bar to switch —
    # no compositor restart. Exits with the compositor ($WM_PID).
    # Mako: notification daemon for the classic bar only. vendibar-pro is its
    # own notification server (island toasts) — mako would race it for the
    # org.freedesktop.Notifications bus name.
    (
        while kill -0 "$WM_PID" 2>/dev/null; do
            local bar_choice
            bar_choice=$(cat "$HOME/.config/vendi/bar" 2>/dev/null || echo classic)
            if [[ "$bar_choice" == "pro" ]] && command -v quickshell >/dev/null; then
                pkill -x mako 2>/dev/null || true
                quickshell -c vendibar-pro >>"$LOG" 2>&1 || true
            else
                if ! pgrep -x mako >/dev/null; then mako >>"$LOG" 2>&1 & fi
                GSK_RENDERER=cairo vendibar >>"$LOG" 2>&1 || true
            fi
            sleep 0.5
        done
    ) &
}

(spawn_desktop) &

# Diagnostic: snapshot the DRM state + whether plymouthd still holds the GPU,
# right before the compositor opens it. If the compositor ever fails with
# EBUSY again, this names exactly what's holding /dev/dri/cardN.
{
    echo "=== pre-compositor $(date '+%T') ==="
    ls -l /dev/dri/ 2>&1
    if pgrep -ax plymouthd >/dev/null 2>&1; then
        echo "WARN: plymouthd STILL RUNNING (likely holding DRM):"; pgrep -ax plymouthd
    else
        echo "plymouthd: gone (good)"
    fi
} >> "$LOG" 2>&1

case "${VENDI_SESSION:-vendiwm}" in
    hyprland)
        exec Hyprland >> "$LOG" 2>&1
        ;;
    vendiwm|*)
        exec vendiwm  >> "$LOG" 2>&1
        ;;
esac
