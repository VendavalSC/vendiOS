#!/usr/bin/env bash
# vendi-session — picks the session compositor and launches it.
#
# Reads /etc/vendi/session.conf if present. Set VENDI_SESSION to one of:
#   hyprland   (current stable default)
#   vendiwm    (experimental; requires udev rendering — may show black screen
#              if not yet implemented on this build)
#
# greetd's initial_session points at this script so users can switch by
# editing the config file instead of /etc/greetd/config.toml.

set -e

VENDI_SESSION=vendiwm
[[ -f /etc/vendi/session.conf ]] && source /etc/vendi/session.conf

# Release the Plymouth splash so the compositor can take over the DRM master.
# Non-fatal: plymouth may not be running (e.g. invoked outside greetd).
plymouth quit --retain-splash 2>/dev/null || true

case "${VENDI_SESSION:-vendiwm}" in
    hyprland)
        exec Hyprland
        ;;
    vendiwm|*)
        exec vendiwm
        ;;
esac
