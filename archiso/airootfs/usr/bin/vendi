#!/usr/bin/env bash
set -euo pipefail

# ── Catppuccin Mocha palette ──────────────────────────────────────────────────
MAUVE=$'\e[38;2;203;166;247m'
LAVENDER=$'\e[38;2;180;190;254m'
BLUE=$'\e[38;2;137;180;250m'
TEXT=$'\e[38;2;205;214;244m'
SUBTEXT=$'\e[38;2;166;173;200m'
OVERLAY=$'\e[38;2;108;112;134m'
GREEN=$'\e[38;2;166;227;161m'
RED=$'\e[38;2;243;139;168m'
YELLOW=$'\e[38;2;249;226;175m'
PEACH=$'\e[38;2;250;179;135m'
TEAL=$'\e[38;2;148;226;213m'
BG_SEL=$'\e[48;2;49;35;73m'
BOLD=$'\e[1m'
DIM=$'\e[2m'
R=$'\e[0m'

# `vendi theme` writes a palette file; let the CLI's own UI follow it.
# (Mocha defaults above stay for root / fresh installs.)
if [[ -f "${HOME}/.config/vendi/shell-theme.zsh" ]]; then
    source "${HOME}/.config/vendi/shell-theme.zsh" 2>/dev/null || true
    MAUVE=$'\e[38;2;'"${VENDI_ACCENT:-203;166;247}"$'m'
    LAVENDER=$'\e[38;2;'"${VENDI_SECOND:-180;190;254}"$'m'
    BLUE=$'\e[38;2;'"${VENDI_BLUE:-137;180;250}"$'m'
    TEXT=$'\e[38;2;'"${VENDI_TEXT:-205;214;244}"$'m'
    OVERLAY=$'\e[38;2;'"${VENDI_DIM:-108;112;134}"$'m'
    GREEN=$'\e[38;2;'"${VENDI_GREEN:-166;227;161}"$'m'
    RED=$'\e[38;2;'"${VENDI_ERR:-243;139;168}"$'m'
    YELLOW=$'\e[38;2;'"${VENDI_YELLOW:-249;226;175}"$'m'
    TEAL=$'\e[38;2;'"${VENDI_TEAL:-148;226;213}"$'m'
fi

LOGO_FILE=/usr/share/vendios/logo.txt

_logo() {
    if [[ -f "$LOGO_FILE" ]]; then
        cat "$LOGO_FILE"
    else
        printf "${MAUVE}${BOLD}  vendiOS${R}\n"
    fi
}

_header() {
    local text=$1 color=${2:-$MAUVE}
    printf "\n${color}${BOLD}  %s${R}\n" "$text"
    printf "${OVERLAY}  %s${R}\n\n" "$(printf '─%.0s' $(seq 1 ${#text}))"
}

_ok()   { printf "  ${GREEN}${BOLD}✓${R}  ${TEXT}%s${R}\n" "$*"; }
_err()  { printf "  ${RED}${BOLD}✗${R}  ${RED}%s${R}\n" "$*" >&2; }
_info() { printf "  ${LAVENDER}${BOLD}·${R}  ${SUBTEXT}%s${R}\n" "$*"; }
_warn() { printf "  ${YELLOW}${BOLD}!${R}  ${YELLOW}%s${R}\n" "$*"; }
_step() { printf "  ${MAUVE}${BOLD}▸${R}  ${TEXT}%s${R}\n" "$*"; }

_kv() {
    local key=$1; shift
    printf "  ${OVERLAY}%-14s${R}${TEXT}%s${R}\n" "$key" "$*"
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_update() {
    _header "system update"
    _step "refreshing mirrors via reflector…"
    reflector --latest 15 --sort rate --save /etc/pacman.d/mirrorlist 2>/dev/null \
        && _ok "mirrors updated" || _warn "reflector failed, using cached mirrors"
    echo
    # The compositor binary can't hot-swap — the running vendiwm keeps the old
    # code until a full session restart. Note its mtime so we can tell the user
    # to relogin if this upgrade replaced it.
    local wm_before; wm_before=$(stat -c %Y /usr/bin/vendiwm 2>/dev/null)
    _step "upgrading packages…"
    pacman -Syu
    _ok "system up to date"
    local wm_after; wm_after=$(stat -c %Y /usr/bin/vendiwm 2>/dev/null)
    if [[ -n "$wm_after" && "$wm_before" != "$wm_after" ]]; then
        echo
        _warn "the compositor (vendiwm) was updated"
        _info "log out and back in to load it — the running session keeps the old one"
    fi
}

cmd_clean() {
    _header "clean cache"
    _step "removing unused package cache…"
    local before after freed
    before=$(du -sh /var/cache/pacman/pkg 2>/dev/null | cut -f1)
    yes | pacman -Sc >/dev/null 2>&1 || true
    after=$(du -sh /var/cache/pacman/pkg 2>/dev/null | cut -f1)
    _ok "package cache: ${before} → ${after}"

    _step "vacuuming systemd journal (keep 2 weeks)…"
    journalctl --vacuum-time=2weeks 2>/dev/null | grep -i 'freed\|deleted' | while read -r l; do _info "$l"; done

    _ok "done"
}

cmd_snapshot() {
    _header "btrfs snapshots"

    # check btrfs
    if ! findmnt -no FSTYPE / 2>/dev/null | grep -q btrfs; then
        _warn "root filesystem is not btrfs — snapshots unavailable"
        return 0
    fi

    [[ $EUID -ne 0 ]] && { _err "snapshots require root (sudo vendi snapshot)"; return 1; }

    local snap_dir='/.snapshots'
    mkdir -p "$snap_dir"

    local ts; ts=$(date +%Y-%m-%d_%H-%M)
    local dest="${snap_dir}/${ts}"

    _step "creating snapshot → ${dest}"
    btrfs subvolume snapshot / "$dest" >/dev/null
    _ok "snapshot created: ${ts}"
    echo

    # list existing
    local snaps=()
    while IFS= read -r s; do snaps+=("$s"); done < <(ls -1 "$snap_dir" 2>/dev/null | sort)
    _info "${#snaps[@]} snapshot(s) stored"
    for s in "${snaps[@]}"; do
        printf "  ${OVERLAY}  %s${R}\n" "$s"
    done

    # enforce max
    local cfg=/etc/vendios/config
    local max=10
    [[ -f "$cfg" ]] && { source "$cfg" 2>/dev/null; max=${VENDIOS_SNAPSHOT_MAX:-10}; }
    while [[ ${#snaps[@]} -gt $max ]]; do
        local oldest="${snaps[0]}"
        _warn "max ${max} snapshots — removing oldest: ${oldest}"
        btrfs subvolume delete "${snap_dir}/${oldest}" >/dev/null
        snaps=("${snaps[@]:1}")
    done
}

cmd_rollback() {
    _header "rollback"

    if ! command -v snapper >/dev/null; then
        _err "snapper not installed — cannot manage rollbacks"
        return 1
    fi
    [[ $EUID -ne 0 ]] && { _err "rollback requires root (sudo vendi rollback)"; return 1; }

    # show available snapshots
    _step "available snapshots:"
    echo
    snapper list | sed 's/^/  /'
    echo

    local target=${1:-}
    if [[ -z "$target" ]]; then
        printf "  ${MAUVE}${BOLD}snapshot number to roll back to: ${R}"
        read -r target
    fi
    [[ -z "$target" ]] && { _warn "no snapshot selected — aborted"; return 1; }

    _step "rolling back to snapshot ${target}…"
    snapper rollback "$target"
    _ok "rollback queued — reboot to enter the previous state"
}

cmd_fetch() {
    fastfetch --logo "$LOGO_FILE" 2>/dev/null || fastfetch
}

cmd_info() {
    _header "vendiOS info"

    local cfg=/etc/vendios/release
    local ver='unknown' codename='unknown' built='unknown'
    if [[ -f "$cfg" ]]; then
        source "$cfg" 2>/dev/null
        ver=${VENDIOS_VERSION:-unknown}
        codename=${VENDIOS_CODENAME:-unknown}
        built=${VENDIOS_BUILD_DATE:-unknown}
    fi

    _kv "version"   "${ver} (${codename})"
    _kv "built"     "${built}"
    _kv "kernel"    "$(uname -r)"
    _kv "hostname"  "$(uname -n)"
    _kv "uptime"    "$(uptime -p 2>/dev/null | sed 's/up //')"
    _kv "packages"  "$(pacman -Q 2>/dev/null | wc -l) installed"
    _kv "disk /"    "$(df -h / 2>/dev/null | awk 'NR==2{print $3" / "$2" ("$5" used)"}')"
    _kv "memory"    "$(free -h 2>/dev/null | awk '/^Mem/{print $3" / "$2}')"
    echo
}

# ── theme engine ──────────────────────────────────────────────────────────────
# `vendi theme <name>` recolors the whole desktop: vendiwm (borders,
# background), vendibar, vendi-menu, alacritty (live-reloads), swaylock.
# Themes are big, opinionated, and self-contained — one name, full look.
# Every theme fills the same semantic slots (base/mantle/crust, text tiers,
# surfaces, ANSI-ish colors) plus A, the single accent everything keys off.

declare -A P
A=

THEMES="mocha latte gruvbox mono think dynamic"

_palette() {
    case "$1" in
    # Catppuccin Mocha — the signature vendiOS dark look.
    mocha) A=cba6f7; P=(
        [base]=1e1e2e [mantle]=181825 [crust]=11111b
        [text]=cdd6f4 [subtext1]=bac2de [subtext0]=a6adc8
        [overlay1]=7f849c [surface2]=585b70 [surface1]=45475a [surface0]=313244
        [blue]=89b4fa [teal]=94e2d5 [green]=a6e3a1 [yellow]=f9e2af
        [red]=f38ba8 [pink]=f5c2e7
    ) ;;
    # Catppuccin Latte — the light one.
    latte) A=8839ef; P=(
        [base]=eff1f5 [mantle]=e6e9ef [crust]=dce0e8
        [text]=4c4f69 [subtext1]=5c5f77 [subtext0]=6c6f85
        [overlay1]=8c8fa1 [surface2]=acb0be [surface1]=bcc0cc [surface0]=ccd0da
        [blue]=1e66f5 [teal]=179299 [green]=40a02b [yellow]=df8e1d
        [red]=d20f39 [pink]=ea76cb
    ) ;;
    # Gruvbox dark — warm retro, orange accent.
    gruvbox) A=fe8019; P=(
        [base]=282828 [mantle]=1d2021 [crust]=141617
        [text]=ebdbb2 [subtext1]=d5c4a1 [subtext0]=bdae93
        [overlay1]=928374 [surface2]=665c54 [surface1]=504945 [surface0]=3c3836
        [blue]=83a598 [teal]=8ec07c [green]=b8bb26 [yellow]=fabd2f
        [red]=fb4934 [pink]=d3869b
    ) ;;
    # Monochrome — pure black and white, no color anywhere.
    mono) A=ffffff; P=(
        [base]=0a0a0a [mantle]=060606 [crust]=000000
        [text]=f2f2f2 [subtext1]=d9d9d9 [subtext0]=b3b3b3
        [overlay1]=808080 [surface2]=595959 [surface1]=404040 [surface0]=262626
        [blue]=cccccc [teal]=c2c2c2 [green]=bfbfbf [yellow]=e6e6e6
        [red]=d9d9d9 [pink]=cccccc
    ) ;;
    # Think — ThinkPad colors: matte black, TrackPoint red accent.
    think) A=e2231a; P=(
        [base]=0d0d0d [mantle]=080808 [crust]=000000
        [text]=e8e8e8 [subtext1]=c8c8c8 [subtext0]=a8a8a8
        [overlay1]=7a7a7a [surface2]=4a4a4a [surface1]=333333 [surface0]=1f1f1f
        [blue]=5f87af [teal]=5fafaf [green]=53a653 [yellow]=d7a65f
        [red]=e2231a [pink]=c46a8c
    ) ;;
    # Dynamic — extracted live from the current wallpaper by vendi-ctl.
    dynamic)
        local out k v
        out=$(vendi-ctl palette 2>/dev/null) || {
            _err "dynamic theme: palette extraction failed (is a wallpaper set?)"
            return 1
        }
        A=
        P=()
        while IFS='=' read -r k v; do
            [[ -n "$k" && -n "$v" ]] || continue
            if [[ "$k" == A ]]; then A=$v; else P[$k]=$v; fi
        done <<< "$out"
        [[ -n "$A" && -n "${P[base]:-}" ]] || { _err "dynamic theme: bad palette"; return 1; }
        ;;
    *) return 1 ;;
    esac
}

# "cba6f7" → "203, 166, 247" (for CSS rgba()).
_rgb() { printf "%d, %d, %d" $((16#${1:0:2})) $((16#${1:2:2})) $((16#${1:4:2})); }
# Desaturate a hex color 60% toward its own gray — neutral surfaces that
# still sit in the theme's value range (the classic bar body uses this).
_neutral() {
    local h=$1 r g b avg
    r=$((16#${h:0:2})); g=$((16#${h:2:2})); b=$((16#${h:4:2}))
    avg=$(( (r + g + b) / 3 ))
    printf "%02x%02x%02x" \
        $(( (r*4 + avg*6) / 10 )) $(( (g*4 + avg*6) / 10 )) $(( (b*4 + avg*6) / 10 ))
}
# "cba6f7" → "203;166;247" (for ANSI truecolor escapes).
_rgbsemi() { printf "%d;%d;%d" $((16#${1:0:2})) $((16#${1:2:2})) $((16#${1:4:2})); }

# Set one key inside the theme { } block of vendiwm.kdl, preserving the rest
# of the file (binds, wallpaper, …).
_kdl_theme_set() {
    local key=$1 val=$2 cfg="$HOME/.config/vendi/vendiwm.kdl"
    mkdir -p "$(dirname "$cfg")"; touch "$cfg"
    awk -v key="$key" -v val="$val" '
        BEGIN { inblock = 0; done = 0; foundblock = 0 }
        {
            if (!inblock && $0 ~ /^[[:space:]]*theme[[:space:]]*\{/) {
                inblock = 1; foundblock = 1; print; next
            }
            if (inblock) {
                if ($0 ~ /^[[:space:]]*\}/) {
                    if (!done) { printf "    %s %s\n", key, val; done = 1 }
                    inblock = 0; print; next
                }
                if ($1 == key) {
                    if (!done) { printf "    %s %s\n", key, val; done = 1 }
                    next
                }
            }
            print
        }
        END {
            if (!foundblock) {
                print ""; print "theme {"
                printf "    %s %s\n", key, val
                print "}"
            }
        }
    ' "$cfg" > "${cfg}.tmp" && mv "${cfg}.tmp" "$cfg"
}

_theme_apply() {
    local name=$1
    _palette "$name" || { _err "unknown theme: ${name} (have: ${THEMES})"; return 1; }
    local a=$A

    mkdir -p "$HOME/.config/vendi" "$HOME/.config/alacritty" "$HOME/.config/kitty" "$HOME/.config/swaylock"

    # ── vendiwm ────────────────────────────────────────────────
    _kdl_theme_set accent     "\"#${a}\""
    _kdl_theme_set inactive   "\"#${P[surface1]}\""
    _kdl_theme_set background "\"#${P[base]}\""
    _ok "vendiwm theme block updated"

    # ── vendibar ───────────────────────────────────────────────
    cat > "$HOME/.config/vendi/vendibar.css" << EOF
/* generated by: vendi theme ${name} */
window { background: transparent; }
.bar {
  padding: 0 14px;
  background: #$(_neutral "${P[surface0]}");
  border: 1px solid rgba($(_rgb "${P[text]}"), 0.06);
  border-radius: 11px;
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 13px;
  color: #${P[text]};
  animation: bar-in 360ms ease-out;
}
@keyframes bar-in {
  from { opacity: 0; margin-top: -10px; }
  to   { opacity: 1; margin-top: 0; }
}
.logo { color: #${a}; font-size: 15px; }
.workspaces button {
  background: none; border: none; box-shadow: none; outline: none;
  min-height: 0; min-width: 0; padding: 0 7px; margin: 0;
  color: #${P[surface2]}; font-size: 13px;
  transition: color 150ms ease;
}
.workspaces button.occupied { color: #${P[subtext0]}; }
.workspaces button.active   { color: #${a}; animation: ws-pop 240ms ease-out; }
.workspaces button:hover    { color: #${P[pink]}; }
@keyframes ws-pop {
  0%   { margin-top: -7px; opacity: 0.2; }
  100% { margin-top: 0;    opacity: 1; }
}
.title { color: #${P[overlay1]}; transition: opacity 130ms ease; }
.title.swap { opacity: 0; }
.clock { color: #${P[text]}; font-weight: 600; }
.status label { padding: 0 7px; color: #${P[subtext0]}; transition: color 150ms ease; }
.status label:hover { color: #${P[text]}; }
.status .bump   { color: #${a}; }
.status .muted   { color: #${P[surface2]}; }
.status .offline { color: #${P[surface2]}; }
.status .low     { color: #${P[red]}; }
.music { padding: 0 7px; }
.music-label { padding: 0; color: #${P[subtext0]}; font-size: 12px; transition: color 150ms ease; }
.music:hover .music-label { color: #${a}; }
EOF
    _ok "vendibar.css written"

    # ── vendi-menu ─────────────────────────────────────────────
    cat > "$HOME/.config/vendi/vendi-menu.css" << EOF
/* generated by: vendi theme ${name} */
window { background: transparent; }
@keyframes menu-pop {
  from { opacity: 0; margin-top: -10px; }
  to   { opacity: 1; margin-top: 0; }
}
.menu-root {
  background: rgba($(_rgb "${P[mantle]}"), 0.72);
  border: 1px solid rgba($(_rgb "$a"), 0.35);
  border-radius: 16px;
  animation: menu-pop 170ms cubic-bezier(0.2, 0.8, 0.3, 1.0);
}
.search {
  all: unset; background: transparent; border: none; box-shadow: none; outline: none;
  margin: 6px 10px; padding: 10px 14px;
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 17px; color: #${P[text]}; caret-color: #${a};
}
.search image { color: #${a}; margin-right: 8px; }
.search placeholder { color: #${P[surface2]}; }
.results { background: transparent; border-top: 1px solid rgba($(_rgb "${P[surface2]}"), 0.45); padding: 6px; }
.hit { border-radius: 10px; padding: 9px 12px; transition: background 120ms ease; }
.hit:hover { background: rgba($(_rgb "${P[surface1]}"), 0.45); }
.hit:selected { background: rgba($(_rgb "$a"), 0.22); }
.hit:selected .hit-name { color: #${a}; }
.hit-name {
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 14px; color: #${P[text]};
}
.actions-root .results { border-top: none; padding: 8px; }
.action-glyph {
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 16px; color: #${a};
}
.action-index {
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 11px; color: #${P[surface1]};
}
.hit:selected .action-index { color: #${P[overlay1]}; }
.hit-comment {
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 11px; color: #${P[surface2]}; margin-left: 12px;
}
.page-title { padding: 12px 18px 4px 18px; }
.page-back {
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 13px; color: #${P[surface2]};
}
.page-name {
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 12px; font-weight: bold; color: #${P[overlay1]};
}
scrolledwindow { background: transparent; }
scrolledwindow undershoot.top, scrolledwindow undershoot.bottom { background: none; }
.key-chord {
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 13px; font-weight: bold; color: #${a};
}
.key-action {
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 13px; color: #${P[subtext0]};
}
EOF
    _ok "vendi-menu.css written"

    # ── alacritty (live-reloads colors in open terminals) ──────
    cat > "$HOME/.config/alacritty/theme.toml" << EOF
# generated by: vendi theme ${name}
[colors.primary]
background = "#${P[base]}"
foreground = "#${P[text]}"

[colors.cursor]
text   = "#${P[base]}"
cursor = "#${a}"

[colors.selection]
text       = "#${P[text]}"
background = "#${P[surface2]}"

[colors.normal]
black   = "#${P[surface1]}"
red     = "#${P[red]}"
green   = "#${P[green]}"
yellow  = "#${P[yellow]}"
blue    = "#${P[blue]}"
magenta = "#${P[pink]}"
cyan    = "#${P[teal]}"
white   = "#${P[subtext1]}"

[colors.bright]
black   = "#${P[surface2]}"
red     = "#${P[red]}"
green   = "#${P[green]}"
yellow  = "#${P[yellow]}"
blue    = "#${P[blue]}"
magenta = "#${P[pink]}"
cyan    = "#${P[teal]}"
white   = "#${P[subtext0]}"
EOF
    if [[ ! -f "$HOME/.config/alacritty/alacritty.toml" ]]; then
        cat > "$HOME/.config/alacritty/alacritty.toml" << 'EOF'
[general]
import = ["~/.config/alacritty/theme.toml"]

[font]
normal = { family = "JetBrainsMono Nerd Font", style = "Regular" }
size = 12

[window]
padding = { x = 12, y = 10 }
EOF
    elif ! grep -q "theme.toml" "$HOME/.config/alacritty/alacritty.toml"; then
        _warn "alacritty.toml exists but doesn't import theme.toml — add: [general] import = [\"~/.config/alacritty/theme.toml\"]"
    fi
    _ok "alacritty theme written"

    # ── kitty (default terminal; SIGUSR1 live-reloads open terminals) ──
    cat > "$HOME/.config/kitty/theme.conf" << EOF
# generated by: vendi theme ${name}
foreground           #${P[text]}
background           #${P[base]}
selection_foreground #${P[text]}
selection_background #${P[surface2]}
cursor               #${a}
cursor_text_color    #${P[base]}
color0  #${P[surface1]}
color1  #${P[red]}
color2  #${P[green]}
color3  #${P[yellow]}
color4  #${P[blue]}
color5  #${P[pink]}
color6  #${P[teal]}
color7  #${P[subtext1]}
color8  #${P[surface2]}
color9  #${P[red]}
color10 #${P[green]}
color11 #${P[yellow]}
color12 #${P[blue]}
color13 #${P[pink]}
color14 #${P[teal]}
color15 #${P[subtext0]}
EOF
    # kitty doesn't watch its config; SIGUSR1 reloads it (incl. theme.conf).
    pkill -USR1 -x kitty 2>/dev/null || true
    _ok "kitty theme written"

    # ── swaylock ───────────────────────────────────────────────
    cat > "$HOME/.config/swaylock/config" << EOF
ignore-empty-password
indicator-radius=90
indicator-thickness=10
color=${P[crust]}
inside-color=${P[base]}
inside-clear-color=${P[base]}
inside-ver-color=${P[base]}
inside-wrong-color=${P[base]}
ring-color=${P[surface1]}
ring-clear-color=${P[yellow]}
ring-ver-color=${a}
ring-wrong-color=${P[red]}
line-color=00000000
line-clear-color=00000000
line-ver-color=00000000
line-wrong-color=00000000
separator-color=00000000
key-hl-color=${a}
bs-hl-color=${P[red]}
text-color=${P[text]}
text-clear-color=${P[text]}
text-ver-color=${P[text]}
text-wrong-color=${P[red]}
font=JetBrainsMono Nerd Font
EOF
    _ok "swaylock theme written"

    # ── shell prompt (zshrc sources this; vars drive prompt/fzf/ls) ──
    cat > "$HOME/.config/vendi/shell-theme.zsh" << EOF
# generated by: vendi theme ${name}
VENDI_ACCENT='$(_rgbsemi "$a")'    VENDI_ACCENT_HEX='#${a}'
VENDI_SECOND='$(_rgbsemi "${P[blue]}")'
VENDI_DIM='$(_rgbsemi "${P[overlay1]}")'
VENDI_ERR='$(_rgbsemi "${P[red]}")'    VENDI_ERR_HEX='#${P[red]}'
VENDI_TEXT='$(_rgbsemi "${P[text]}")'    VENDI_TEXT_HEX='#${P[text]}'
VENDI_BASE_HEX='#${P[base]}'    VENDI_SURFACE_HEX='#${P[surface0]}'
VENDI_BLUE='$(_rgbsemi "${P[blue]}")'
VENDI_TEAL='$(_rgbsemi "${P[teal]}")'    VENDI_TEAL_HEX='#${P[teal]}'
VENDI_GREEN='$(_rgbsemi "${P[green]}")'    VENDI_GREEN_HEX='#${P[green]}'
VENDI_YELLOW='$(_rgbsemi "${P[yellow]}")'
VENDI_PINK_HEX='#${P[pink]}'
EOF
    _ok "shell prompt theme written (new terminals pick it up)"

    # ── shard logo (recolor its two faces to the accent) ───────
    local shard_src=/usr/share/vendios/shard.txt shard="$HOME/.config/vendi/shard.txt"
    if [[ -f "$shard_src" ]]; then
        local lt dk
        lt=$(_rgbsemi "$a")
        dk=$(printf "%d;%d;%d" $((16#${a:0:2}*55/100)) $((16#${a:2:2}*55/100)) $((16#${a:4:2}*55/100)))
        sed -e "s/38;2;205;167;250/38;2;${lt}/g" -e "s/38;2;124;77;191/38;2;${dk}/g" "$shard_src" > "$shard"
    else
        shard=$shard_src
    fi

    # ── fastfetch ──────────────────────────────────────────────
    mkdir -p "$HOME/.config/fastfetch"
    cat > "$HOME/.config/fastfetch/config.jsonc" << EOF
// generated by: vendi theme ${name}
{
  "\$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "${shard}",
    "padding": { "top": 1, "right": 4 }
  },
  "display": {
    "separator": "  ",
    "color": {
      "keys":   "38;2;$(_rgbsemi "$a")",
      "title":  "38;2;$(_rgbsemi "$a")",
      "output": "38;2;$(_rgbsemi "${P[text]}")"
    },
    "key": { "width": 12 }
  },
  "modules": [
    { "type": "title",    "keyColor": "38;2;$(_rgbsemi "$a")" },
    { "type": "separator", "string": "─" },
    { "type": "os",       "key": "os",       "keyColor": "38;2;$(_rgbsemi "$a")" },
    { "type": "kernel",   "key": "kernel",   "keyColor": "38;2;$(_rgbsemi "${P[blue]}")" },
    { "type": "uptime",   "key": "uptime",   "keyColor": "38;2;$(_rgbsemi "${P[teal]}")" },
    { "type": "packages", "key": "packages", "keyColor": "38;2;$(_rgbsemi "${P[green]}")" },
    { "type": "shell",    "key": "shell",    "keyColor": "38;2;$(_rgbsemi "${P[yellow]}")" },
    { "type": "terminal", "key": "terminal", "keyColor": "38;2;$(_rgbsemi "${P[pink]}")" },
    { "type": "cpu",      "key": "cpu",      "keyColor": "38;2;$(_rgbsemi "${P[red]}")" },
    { "type": "gpu",      "key": "gpu",      "keyColor": "38;2;$(_rgbsemi "${P[pink]}")" },
    { "type": "memory",   "key": "memory",   "keyColor": "38;2;$(_rgbsemi "${P[blue]}")" },
    { "type": "disk",     "key": "disk",     "keyColor": "38;2;$(_rgbsemi "${P[overlay1]}")" },
    { "type": "separator", "string": "─" },
    { "type": "colors", "paddingLeft": 2, "symbol": "circle" }
  ]
}
EOF
    _ok "fastfetch theme written"

    # ── classic bar (vendibar) CSS — recolored per theme ──────
    # vendibar loads ~/.config/vendi/vendibar.css wholesale when present, so
    # generating it here makes the whole classic bar follow the theme (surface
    # background, text tiers, accent) instead of only the cairo logo/eq. The
    # bar is bounced below so it reloads.
    cat > "$HOME/.config/vendi/vendibar.css" << EOF
/* generated by: vendi theme ${name} — do not edit (rewritten on theme switch) */
window { background: transparent; }
.bar {
  padding: 0 14px;
  background: #${P[surface0]};
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 11px;
  font-family: "JetBrainsMonoNL Nerd Font", "JetBrainsMono Nerd Font", monospace;
  font-size: 13px;
  color: #${P[text]};
  animation: bar-in 360ms ease-out;
}
@keyframes bar-in { from { opacity: 0; margin-top: -10px; } to { opacity: 1; margin-top: 0; } }
.logo { color: #${a}; font-size: 15px; }
.workspaces button {
  background: none; border: none; box-shadow: none; outline: none;
  min-height: 0; min-width: 0; padding: 0 7px; margin: 0;
  color: #${P[surface2]}; font-size: 13px; transition: color 150ms ease;
}
.workspaces button.occupied { color: #${P[subtext0]}; }
.workspaces button.active { color: #${a}; animation: ws-pop 240ms ease-out; }
.workspaces button:hover { color: #${P[pink]}; }
@keyframes ws-pop { 0% { margin-top: -7px; opacity: 0.2; } 100% { margin-top: 0; opacity: 1; } }
.title { color: #${P[overlay1]}; transition: opacity 130ms ease; }
.title.swap { opacity: 0; }
.clock { color: #${P[text]}; font-weight: 600; }
.status label { padding: 0 7px; color: #${P[subtext0]}; transition: color 150ms ease; }
.status label:hover { color: #${P[text]}; }
.status .bump { color: #${a}; }
.status .muted { color: #${P[surface2]}; }
.status .offline { color: #${P[surface2]}; }
.status .low { color: #${P[red]}; }
.music { padding: 0 7px; }
.music-label { padding: 0; color: #${P[subtext0]}; font-size: 12px; transition: color 150ms ease; }
.music:hover .music-label { color: #${a}; }
EOF
    _ok "classic bar theme written"

    # ── remember + bar accent for cairo widgets ────────────────
    cat > "$HOME/.config/vendi/theme-state" << EOF
THEME=${name}
ACCENT_HEX=${a}
EOF

    # ── apply live (no session restart) ────────────────────────
    # vendiwm re-reads its config over IPC; vendibar-pro follows theme-state
    # on its own; the classic GTK bar reads its CSS at startup, so bounce it
    # (the session's bar supervisor respawns it).
    if [[ -n "${VENDIWM_SOCK:-}" || -n "${WAYLAND_DISPLAY:-}" ]]; then
        vendi-ctl reload >/dev/null 2>&1 || true
        pkill -x vendibar 2>/dev/null || true
        _ok "applied live"
    fi
    _ok "theme: ${name}"
}

_theme_desc() {
    case "$1" in
        mocha)   echo "catppuccin mocha — the signature dark look" ;;
        latte)   echo "catppuccin latte — light and clean" ;;
        gruvbox) echo "gruvbox dark — warm retro, orange accent" ;;
        mono)    echo "monochrome — pure black and white" ;;
        think)   echo "ThinkPad — matte black, TrackPoint red" ;;
        dynamic) echo "generated from your current wallpaper" ;;
    esac
}

cmd_theme() {
    local state_file="$HOME/.config/vendi/theme-state"
    local THEME=mocha ACCENT_HEX=
    [[ -f "$state_file" ]] && source "$state_file"

    local sub=${1:-}
    case "$sub" in
        "")
            _header "theme"
            _kv "current" "$THEME"
            echo
            local t
            for t in $THEMES; do
                if [[ "$t" == "$THEME" ]]; then
                    printf "  ${GREEN}${BOLD}● %-9s${R}${SUBTEXT}%s${R}\n" "$t" "$(_theme_desc "$t")"
                else
                    printf "  ${OVERLAY}○ ${R}${TEXT}%-9s${R}${OVERLAY}%s${R}\n" "$t" "$(_theme_desc "$t")"
                fi
            done
            echo
            _info "vendi theme <name> to switch"
            ;;
        list)
            # Machine-readable, for vendi-menu.
            local t
            for t in $THEMES; do echo "$t"; done
            ;;
        *)
            _theme_apply "$sub"
            ;;
    esac
}

# ── bar flavor ────────────────────────────────────────────────────────────────
# `vendi bar <classic|pro>` switches the status bar without touching the
# compositor: write the choice, kill the running bar, and the session's bar
# supervisor respawns the right one (and sorts out mako).
cmd_bar() {
    local choice=${1:-}
    local cur
    cur=$(cat "$HOME/.config/vendi/bar" 2>/dev/null || echo classic)
    case "$choice" in
        "")
            _header "bar"
            _kv "current" "$cur"
            _info "vendi bar <classic|pro> to switch"
            ;;
        classic|pro)
            mkdir -p "$HOME/.config/vendi"
            echo "$choice" > "$HOME/.config/vendi/bar"
            pkill -x vendibar 2>/dev/null || true
            pkill -x quickshell 2>/dev/null || true
            _ok "bar: ${choice}"
            ;;
        *)
            _err "unknown bar: ${choice} (have: classic pro)"
            return 1
            ;;
    esac
}

# ── connectivity TUIs ─────────────────────────────────────────────────────────
# Small fzf-driven pickers in the same visual language as the package
# installer. The bar's wifi/bluetooth/battery icons summon these in a
# floating terminal.

# fzf with the vendi look — accent comes from the active theme.
_fzf() {
    local prompt=$1; shift
    local accent="#cba6f7"
    [[ -f "$HOME/.config/vendi/theme-state" ]] && {
        local ACCENT_HEX=; source "$HOME/.config/vendi/theme-state" 2>/dev/null
        [[ -n "$ACCENT_HEX" ]] && accent="#${ACCENT_HEX}"
    }
    fzf --reverse --height=80% --border=rounded --prompt="$prompt" \
        --color="pointer:${accent},prompt:${accent},border:${accent},hl:${accent},hl+:${accent},bg+:-1,fg+:regular:bold,header:dim" \
        "$@"
}

cmd_wifi() {
    command -v nmcli >/dev/null || { _err "NetworkManager not available"; return 1; }
    _header "wifi"
    local cur
    cur=$(nmcli -t -f active,ssid dev wifi 2>/dev/null | awk -F: '$1=="yes"{print $2; exit}')
    [[ -n "$cur" ]] && _kv "connected" "$cur"
    _step "scanning…"
    nmcli dev wifi rescan 2>/dev/null || true
    sleep 2
    # TSV: SIGNAL · SECURITY · SSID (SSID last — it may contain spaces).
    local list
    list=$(nmcli -t -f IN-USE,SSID,SIGNAL,SECURITY dev wifi list 2>/dev/null \
        | awk -F: 'length($2) && !seen[$2]++ {
            mark = ($1=="*") ? "●" : " ";
            sec  = length($4) ? $4 : "open";
            printf "%s %3s%%\t%s\t%s\n", mark, $3, sec, $2
          }')
    [[ -n "$list" ]] || { _warn "no networks found"; return 0; }
    local choice
    choice=$(printf '%s\n' "$list" | _fzf "wifi> " --delimiter='\t' \
        --header="enter connect · esc cancel") || return 0
    local ssid sec
    ssid=$(printf '%s' "$choice" | cut -f3)
    sec=$(printf '%s' "$choice" | cut -f2)
    [[ -n "$ssid" ]] || return 0

    # Known connection → just bring it up. New network → ask for a key.
    if nmcli -t -f NAME connection show 2>/dev/null | grep -qxF "$ssid"; then
        _step "connecting to ${ssid}…"
        nmcli connection up "$ssid" && _ok "connected: ${ssid}" || _err "failed to connect"
    elif [[ "$sec" == "open" ]]; then
        _step "connecting to ${ssid} (open)…"
        nmcli dev wifi connect "$ssid" && _ok "connected: ${ssid}" || _err "failed to connect"
    else
        printf "  ${MAUVE}${BOLD}passphrase for %s: ${R}" "$ssid"
        local pw; read -rs pw; echo
        _step "connecting to ${ssid}…"
        nmcli dev wifi connect "$ssid" password "$pw" \
            && _ok "connected: ${ssid}" || _err "failed to connect"
    fi
    sleep 1
}

cmd_bt() {
    command -v bluetoothctl >/dev/null || { _err "bluez not available"; return 1; }
    _header "bluetooth"
    bluetoothctl power on >/dev/null 2>&1 || true
    _step "scanning (8s)…"
    bluetoothctl --timeout 8 scan on >/dev/null 2>&1 || true
    local connected paired all
    connected=$(bluetoothctl devices Connected 2>/dev/null | awk '{print $2}')
    # "MAC<TAB>● Name" lines; connected devices marked.
    all=$(bluetoothctl devices 2>/dev/null | while read -r _ mac name; do
        local mark=" "
        grep -qxF "$mac" <<< "$connected" && mark="●"
        printf '%s\t%s %s\n' "$mac" "$mark" "$name"
    done)
    [[ -n "$all" ]] || { _warn "no devices found — put the device in pairing mode and retry"; return 0; }
    local choice
    choice=$(printf '%s\n' "$all" | _fzf "bluetooth> " --delimiter='\t' --with-nth=2 \
        --header="enter connect/disconnect · esc cancel") || return 0
    local mac; mac=$(printf '%s' "$choice" | cut -f1)
    [[ -n "$mac" ]] || return 0
    if grep -qxF "$mac" <<< "$connected"; then
        _step "disconnecting ${mac}…"
        bluetoothctl disconnect "$mac" >/dev/null && _ok "disconnected" || _err "disconnect failed"
    else
        _step "pairing + connecting ${mac}…"
        bluetoothctl pair "$mac"    >/dev/null 2>&1 || true
        bluetoothctl trust "$mac"   >/dev/null 2>&1 || true
        bluetoothctl connect "$mac" >/dev/null && _ok "connected" || _err "connect failed"
    fi
    sleep 1
}

cmd_audio() {
    command -v wpctl >/dev/null || { _err "wireplumber not available"; return 1; }
    _header "audio"
    local vol; vol=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)
    [[ -n "$vol" ]] && _kv "volume" "$vol"
    # Sink list from wpctl status: lines like "│  *   58. Built-in Audio [vol: 0.80]".
    local sinks
    sinks=$(wpctl status 2>/dev/null | sed -n '/Sinks:/,/Sources:/p' \
        | grep -E '[0-9]+\.' \
        | sed -E 's/[│├└─]*//g; s/^ +//; s/ \[vol:.*//' \
        | awk '{ star=($1=="*")?"●":" "; if ($1=="*") { $1="" }; id=$1; sub(/\./,"",id); $1=""; sub(/^ +/,""); printf "%s\t%s %s\n", id, star, $0 }')
    local actions="+\t▲ volume up 5%
-\t▼ volume down 5%
m\t⊘ toggle mute"
    local choice
    choice=$(printf '%s\n%s\n' "$actions" "$sinks" | _fzf "audio> " --delimiter='\t' --with-nth=2 \
        --header="enter apply · esc done") || return 0
    local id; id=$(printf '%s' "$choice" | cut -f1)
    case "$id" in
        +) wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+ ;;
        -) wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ;;
        m) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
        *) [[ -n "$id" ]] && { wpctl set-default "$id" && _ok "default sink set"; } ;;
    esac
    cmd_audio   # loop until esc
}

cmd_power() {
    command -v powerprofilesctl >/dev/null || { _err "power-profiles-daemon not available"; return 1; }
    _header "power profile"
    local cur; cur=$(powerprofilesctl get 2>/dev/null)
    _kv "current" "$cur"
    local choice
    choice=$(powerprofilesctl list 2>/dev/null | grep -oE '^[* ]+[a-z-]+:' \
        | tr -d ' *:' \
        | awk -v cur="$cur" '{ mark=($0==cur)?"●":" "; printf "%s\t%s %s\n", $0, mark, $0 }' \
        | _fzf "power> " --delimiter='\t' --with-nth=2 --header="enter apply · esc cancel") || return 0
    local profile; profile=$(printf '%s' "$choice" | cut -f1)
    [[ -n "$profile" ]] && { powerprofilesctl set "$profile" && _ok "profile: ${profile}"; }
    sleep 1
}

# ── fingerprint ─────────────────────────────────────────────────────────────
# Enroll / manage fingerprints (fprintd). Once a print is enrolled it unlocks
# vendilock (swipe at the lock screen), sudo, and the greeter automatically —
# the PAM stacks were wired at install time.
cmd_fingerprint() {
    command -v fprintd-enroll >/dev/null || { _err "fprintd not installed"; return 1; }
    if ! fprintd-list "$USER" >/dev/null 2>&1 && \
       ! fprintd-enroll --help >/dev/null 2>&1; then
        _err "no fingerprint reader detected"
        return 1
    fi
    local sub=${1:-enroll}
    case "$sub" in
        enroll|"")
            _header "fingerprint"
            _info "place your finger on the reader, lift, repeat until done"
            echo
            local finger=${2:-right-index-finger}
            if fprintd-enroll -f "$finger" "$USER"; then
                _ok "enrolled ${finger} — you can now swipe to unlock"
            else
                _err "enrollment failed or cancelled"
                return 1
            fi
            ;;
        list)
            _header "fingerprint"
            fprintd-list "$USER" 2>/dev/null | sed 's/^/  /' || _info "no prints enrolled"
            ;;
        delete|clear)
            fprintd-delete "$USER" && _ok "all fingerprints removed"
            ;;
        *)
            _err "usage: vendi fingerprint [enroll [finger] | list | delete]"
            return 1
            ;;
    esac
}

# ── displays ────────────────────────────────────────────────────────────────
# Arrange monitors from the terminal (the Pro bar has a GUI tab; this is the
# classic-bar equivalent). Wraps `vendi-ctl output {list,scale,position,mode,
# reset}`. The plain list format is:  "  <name>  <WxH@hz>  scale <s>  at <x,y>".
_out_field() { vendi-ctl output list 2>/dev/null | awk -v n="$1" -v f="$2" '$1==n{print $f}'; }

cmd_display() {
    command -v vendi-ctl >/dev/null || { _err "vendi-ctl not available"; return 1; }
    _header "displays"
    local list; list=$(vendi-ctl output list 2>/dev/null)
    if ! printf '%s' "$list" | grep -qE ' at '; then
        _err "no monitors detected (is vendiwm running?)"; return 1
    fi
    local choice
    choice=$(printf '%s\n' "$list" \
        | awk 'NF>=6 && $5=="at"{ printf "%s\t󰍹 %-10s %-13s scale %-5s @ %s\n", $1, $1, $2, $4, $6 }' \
        | _fzf "display> " --delimiter='\t' --with-nth=2 --header="enter configure · esc done") || return 0
    local name; name=$(printf '%s' "$choice" | cut -f1)
    [[ -z "$name" ]] && return 0
    _display_actions "$name"
    cmd_display   # loop until esc
}

_display_actions() {
    local name=$1 act
    act=$(printf '%b' "scale\t󰊓 scale\nposition\t󰍹 position (arrange)\nmode\t󰧨 resolution\nreset\t󰑓 reset to auto\n" \
        | _fzf "${name}> " --delimiter='\t' --with-nth=2 --header="configure ${name} · esc back") || return 0
    case "$(printf '%s' "$act" | cut -f1)" in
        scale)    _display_scale "$name" ;;
        position) _display_position "$name" ;;
        mode)     _display_mode "$name" ;;
        reset)    vendi-ctl output reset "$name" && _ok "${name}: reset to auto" ;;
    esac
}

_display_scale() {
    local name=$1 s
    s=$(printf '%b' "1.0\n1.25\n1.5\n1.75\n2.0\n" \
        | _fzf "${name} scale> " --header="enter apply · esc back") || return 0
    [[ -n "$s" ]] && vendi-ctl output scale "$name" "$s" && _ok "${name}: scale ${s}"
}

_display_mode() {
    local name=$1 m
    _info "current: $(_out_field "$name" 2)"
    read -rp "  new mode (WxH[@hz], blank to cancel): " m
    [[ -n "$m" ]] && vendi-ctl output mode "$name" "$m" && _ok "${name}: mode ${m}"
}

_display_position() {
    local name=$1
    local others; others=$(vendi-ctl output list 2>/dev/null | awk -v n="$name" 'NF>=6 && $5=="at" && $1!=n{print}')
    if [[ -z "$others" ]]; then
        vendi-ctl output position "$name" 0 0 && _ok "${name}: primary at 0,0"
        return 0
    fi
    local ref
    ref=$(printf '%s\n' "$others" \
        | awk 'NF>=6{printf "%s\t%s (%s)\n",$1,$1,$2}' \
        | _fzf "place ${name} next to> " --delimiter='\t' --with-nth=2 --header="reference monitor · esc back") || return 0
    local rname; rname=$(printf '%s' "$ref" | cut -f1)
    [[ -z "$rname" ]] && return 0
    local side
    side=$(printf '%b' "right\nleft\nabove\nbelow\n" \
        | _fzf "side> " --header="${name} goes to the ___ of ${rname}") || return 0
    [[ -z "$side" ]] && return 0
    # Reference + this monitor geometry. Mode is physical WxH; positions are in
    # logical global space, so divide each width/height by its scale.
    local rmode rpos rscale mmode mscale
    rmode=$(_out_field "$rname" 2); rpos=$(_out_field "$rname" 6); rscale=$(_out_field "$rname" 4)
    mmode=$(_out_field "$name"  2); mscale=$(_out_field "$name"  4)
    local rw=${rmode%@*}; local rh=${rw#*x}; rw=${rw%x*}
    local mw=${mmode%@*}; local mh=${mw#*x}; mw=${mw%x*}
    local rx=${rpos%,*}; local ry=${rpos#*,}
    local nx ny
    read -r nx ny < <(awk -v rw="$rw" -v rh="$rh" -v rx="$rx" -v ry="$ry" \
        -v mw="$mw" -v mh="$mh" -v rs="${rscale:-1}" -v ms="${mscale:-1}" -v side="$side" 'BEGIN{
            rwl=int(rw/rs); rhl=int(rh/rs); mwl=int(mw/ms); mhl=int(mh/ms);
            if(side=="right"){nx=rx+rwl; ny=ry}
            else if(side=="left"){nx=rx-mwl; ny=ry}
            else if(side=="above"){nx=rx; ny=ry-mhl}
            else {nx=rx; ny=ry+rhl}
            print nx, ny }')
    vendi-ctl output position "$name" "$nx" "$ny" && _ok "${name}: ${side} of ${rname} (${nx},${ny})"
}

# ── screensaver ───────────────────────────────────────────────────────────────
# Pick the looping video the compositor plays after idle (off on battery by
# default). Standalone — not the lock screen. Library: ~/Videos/Screensavers,
# active video persisted to ~/.config/vendi/screensaver (mirrors wallpaper).
_ss_state() { echo "${XDG_CONFIG_HOME:-$HOME/.config}/vendi/screensaver"; }
_ss_dir()   { echo "$HOME/Videos/Screensavers"; }
_ss_current() { local s; s=$(_ss_state); [[ -f "$s" ]] && head -n1 "$s"; }

cmd_screensaver() {
    local sub=${1:-pick}
    local state dir; state=$(_ss_state); dir=$(_ss_dir)
    mkdir -p "$(dirname "$state")" "$dir"
    case "$sub" in
        off|none|clear)
            : > "$state"; _ok "screensaver off" ;;
        test|preview)
            local v; v=$(_ss_current)
            [[ -n "$v" && -f "$v" ]] || { _err "no screensaver set — run 'vendi screensaver'"; return 1; }
            _info "playing ${v##*/} fullscreen — move the mouse or press a key to stop"
            # Route through the compositor so the preview is the real thing:
            # fullscreen above the bar, dismissed on any input.
            vendi-ctl screensaver ;;
        list)
            _header "screensaver"
            local cur; cur=$(_ss_current)
            shopt -s nullglob
            local found=0 f
            for f in "$dir"/*.{mp4,mkv,webm,mov,m4v,avi}; do
                found=1; local mark=" "; [[ "$f" == "$cur" ]] && mark="●"
                printf "  %s %s\n" "$mark" "${f##*/}"
            done
            shopt -u nullglob
            [[ "$found" == 0 ]] && _info "no videos in ${dir}" ;;
        pick|"")
            command -v fzf >/dev/null || { _err "fzf not available"; return 1; }
            shopt -s nullglob
            local vids=("$dir"/*.{mp4,mkv,webm,mov,m4v,avi})
            shopt -u nullglob
            [[ ${#vids[@]} -gt 0 ]] || { _err "no videos in ${dir} — drop some in there first"; return 1; }
            local cur; cur=$(_ss_current)
            local choice
            choice=$(printf '%s\n' "off — disable" "${vids[@]}" \
                | awk -v cur="$cur" '{ if($0=="off — disable"){print "\t"$0} else {m=($0==cur)?"●":" "; n=$0; sub(/.*\//,"",n); printf "%s\t%s %s\n",$0,m,n} }' \
                | _fzf "screensaver> " --delimiter='\t' --with-nth=2 --header="enter set · esc cancel") || return 0
            local sel; sel=$(printf '%s' "$choice" | cut -f1)
            [[ -z "$sel" ]] && return 0
            if [[ "$sel" == "off — disable" ]]; then : > "$state"; _ok "screensaver off"
            else echo "$sel" > "$state"; _ok "screensaver: ${sel##*/}"; fi ;;
        *)
            # treat the arg as a path to set directly
            local p="$sub"
            [[ -f "$p" ]] || { _err "not a file: ${p}"; return 1; }
            realpath "$p" > "$state" 2>/dev/null || echo "$p" > "$state"
            _ok "screensaver: ${p##*/}" ;;
    esac
}

cmd_help() {
    _logo
    printf "\n  ${OVERLAY}Minimal. Modern. Yours.${R}\n\n"

    printf "  ${MAUVE}${BOLD}commands${R}\n\n"

    _cmd() {
        printf "  ${LAVENDER}${BOLD}%-14s${R}${OVERLAY}%s${R}\n" "$1" "$2"
    }

    _cmd "update"   "refresh mirrors and upgrade all packages"
    _cmd "clean"    "remove cached packages and vacuum journal"
    _cmd "snapshot" "create / manage btrfs snapshots"
    _cmd "rollback" "roll back to a previous snapshot"
    _cmd "theme"    "recolor the whole desktop (mocha latte gruvbox mono think)"
    _cmd "appearance" "light / dark / auto — apps follow (light|dark|auto|toggle)"
    _cmd "wallpaper" "set wallpaper, or 'dynamic set <day> <night> [dusk]'"
    _cmd "bar"      "switch the status bar (classic / pro)"
    _cmd "display"  "arrange monitors — scale, position, resolution"
    _cmd "wifi"     "scan and connect to wireless networks"
    _cmd "bt"       "pair and connect bluetooth devices"
    _cmd "audio"    "pick output sink, volume, mute"
    _cmd "power"    "switch power profile"
    _cmd "screensaver" "pick the idle video screensaver (~/Videos/Screensavers)"
    _cmd "fingerprint" "enroll a fingerprint to unlock (swipe at the lock)"
    _cmd "fetch"    "show system info with vendiOS logo"
    _cmd "info"     "show distro version and system summary"
    _cmd "help"     "show this message"

    printf "\n  ${OVERLAY}run with sudo for snapshot, rollback, update${R}\n\n"
}

# ── appearance (light / dark, app-wide) ───────────────────────────────────────
# Sets the freedesktop color-scheme so portal-aware apps (Firefox, GTK4, Qt)
# switch light/dark live, plus GTK3/4 settings.ini for the rest.
APPEARANCE_FILE="$HOME/.config/vendi/appearance"

_appearance_apply() {
    local mode="$1" prefer dark_bool gtk_theme
    if [[ "$mode" == dark ]]; then
        prefer="prefer-dark"; dark_bool="1"; gtk_theme="Adwaita-dark"
    else
        prefer="prefer-light"; dark_bool="0"; gtk_theme="Adwaita"
    fi
    if command -v gsettings >/dev/null; then
        # The running gtk xdg-desktop-portal turns this into
        # org.freedesktop.appearance color-scheme, which Firefox & co. follow.
        gsettings set org.gnome.desktop.interface color-scheme "$prefer" 2>/dev/null || true
        gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme" 2>/dev/null || true
    fi
    local d
    for d in "$HOME/.config/gtk-3.0" "$HOME/.config/gtk-4.0"; do
        mkdir -p "$d"
        cat > "$d/settings.ini" <<EOF
[Settings]
gtk-theme-name=$gtk_theme
gtk-application-prefer-dark-theme=$dark_bool
EOF
    done
}

# Light/dark of the current wallpaper, via vendi-ctl's luminance analysis.
_wallpaper_mode() { vendi-ctl palette 2>/dev/null | sed -n 's/^mode=//p'; }

_appearance_current() {
    local saved; saved="$(cat "$APPEARANCE_FILE" 2>/dev/null)"
    if [[ "$saved" == auto ]]; then _wallpaper_mode
    elif [[ "$saved" == light || "$saved" == dark ]]; then printf '%s\n' "$saved"
    else case "$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null)" in
            *dark*) echo dark ;; *) echo light ;; esac
    fi
}

cmd_appearance() {
    case "${1:-status}" in
        light|dark)
            _appearance_apply "$1"; printf '%s\n' "$1" > "$APPEARANCE_FILE"
            _ok "appearance: $1" ;;
        auto)
            local m; m="$(_wallpaper_mode)"; [[ -z "$m" ]] && m="dark"
            _appearance_apply "$m"; printf 'auto\n' > "$APPEARANCE_FILE"
            _ok "appearance: auto → $m" ;;
        toggle)
            [[ "$(_appearance_current)" == dark ]] && cmd_appearance light || cmd_appearance dark ;;
        status) _appearance_current ;;
        *) _err "usage: vendi appearance [light|dark|auto|toggle|status]"; return 1 ;;
    esac
}

# ── wallpaper (wraps vendi-ctl, follows light/dark when in auto) ───────────────
WPDYN_FILE="$HOME/.config/vendi/wallpaper-dynamic"

_wallpaper_followup() {
    # After any wallpaper change, if appearance is in auto mode, match it.
    [[ "$(cat "$APPEARANCE_FILE" 2>/dev/null)" == auto ]] || return 0
    local m; m="$(_wallpaper_mode)"; [[ -n "$m" ]] && _appearance_apply "$m"
}

# Raw set (no side effects) — used by the day/night scheduler so re-applying a
# slot doesn't count as a "manual" pick.
_wallpaper_set() { vendi-ctl wallpaper "$@" || return 1; _wallpaper_followup; }

cmd_wallpaper() {
    case "${1:-}" in
        dynamic) shift; cmd_wallpaper_dynamic "$@" ;;
        "") _err "usage: vendi wallpaper <path|random|next|default|list|dynamic>"; return 1 ;;
        *)  _wallpaper_set "$@" || return 1
            # A manual pick wins: stop the day/night schedule from overwriting it.
            if systemctl --user is-active vendi-wallpaper-dynamic.timer >/dev/null 2>&1; then
                _wpdyn_setkey enabled 0
                systemctl --user disable --now vendi-wallpaper-dynamic.timer >/dev/null 2>&1 || true
            fi ;;
    esac
}

# Day/night wallpaper GROUPS. A group is a SUBFOLDER of ~/Pictures/Wallpapers/
# (e.g. "Tahoe 26/", "Ventura 13/") holding that collection's variants. Each
# variant is auto-matched to one of four time slots (sunrise, day, afternoon,
# night) by a keyword in its filename, falling back to sorted position. You pick
# ONE active group; a user timer applies that group's slot for the current time.
# Times are GLOBAL and customizable. Config (~/.config/vendi/wallpaper-dynamic):
#   enabled=0|1
#   active=<group folder name>
#   time|sunrise|HH:MM   (×4)
WP_DIR="$HOME/Pictures/Wallpapers"
WPDYN_SLOTS=(sunrise day afternoon night)
WPDYN_DEFTIME=(06:30 08:00 18:00 21:00)

_wpdyn_kw() {  # filename keywords (case-insensitive ERE) per slot.
    # NOTE: keep these non-overlapping — "noon" would match "afterNOON", so day
    # uses "midday"/"light" instead. afternoon is checked for "afternoon" too.
    case "$1" in
        sunrise)   echo 'sunrise|dawn|morning|sunup|early' ;;
        day)       echo 'day|midday|daylight|light|noon' ;;
        afternoon) echo 'afternoon|dusk|evening|sunset|golden' ;;
        night)     echo 'night|midnight|dark' ;;
    esac
}

# Resolve a group folder's four slot images → "sunrise|day|afternoon|night".
# Keyword pass first (afternoon claims its file before day, so "afternoon-dusk"
# can't be stolen by day), then carry-fill any empty slot from its neighbours.
_wpdyn_resolve() {
    local dir="$1"; local -a imgs=(); local f s pick i
    while IFS= read -r f; do imgs+=("$f"); done < <(find "$dir" -maxdepth 1 -type f \
        \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' \) 2>/dev/null | sort)
    if (( ${#imgs[@]} == 0 )); then echo "|||"; return; fi
    local -A m=()
    # claim most-specific slots first so afternoon wins "afternoon-*" over day.
    for s in afternoon night sunrise day; do
        for f in "${imgs[@]}"; do
            [[ " ${m[*]} " == *" $f "* ]] && continue           # already claimed
            printf '%s' "${f##*/}" | grep -qiE "$(_wpdyn_kw "$s")" && { m[$s]="$f"; break; }
        done
    done
    # carry-fill: forward then backward, so leading empties (e.g. sunrise with no
    # dedicated image) inherit the nearest defined slot (usually day).
    local last=""
    for s in "${WPDYN_SLOTS[@]}"; do
        [[ -n "${m[$s]:-}" ]] && last="${m[$s]}" || m[$s]="$last"
    done
    last=""
    for (( i=${#WPDYN_SLOTS[@]}-1; i>=0; i-- )); do
        s="${WPDYN_SLOTS[$i]}"
        [[ -n "${m[$s]:-}" ]] && last="${m[$s]}" || m[$s]="$last"
    done
    printf '%s|%s|%s|%s\n' "${m[sunrise]}" "${m[day]}" "${m[afternoon]}" "${m[night]}"
}

_wpdyn_init() {
    [[ -f "$WPDYN_FILE" ]] && grep -q '^time|' "$WPDYN_FILE" && return
    mkdir -p "$(dirname "$WPDYN_FILE")"
    { echo "enabled=0"; echo "active="
      local i; for i in "${!WPDYN_SLOTS[@]}"; do echo "time|${WPDYN_SLOTS[$i]}|${WPDYN_DEFTIME[$i]}"; done
    } > "$WPDYN_FILE"
}

_wpdyn_get() { _wpdyn_init; sed -n "s|^$1=||p" "$WPDYN_FILE"; }
_wpdyn_setkey() {  # key value  (enabled / active)
    _wpdyn_init; local k="$1" v="$2" tmp; tmp="$(mktemp)"
    if grep -q "^$k=" "$WPDYN_FILE"; then sed "s#^$k=.*#$k=$v#" "$WPDYN_FILE" > "$tmp"
    else cp "$WPDYN_FILE" "$tmp"; echo "$k=$v" >> "$tmp"; fi
    mv "$tmp" "$WPDYN_FILE"
}
_wpdyn_settime() {  # slot HH:MM
    _wpdyn_init; local s="$1" t="$2" tmp; tmp="$(mktemp)"
    if grep -q "^time|$s|" "$WPDYN_FILE"; then sed "s#^time|$s|.*#time|$s|$t#" "$WPDYN_FILE" > "$tmp"
    else cp "$WPDYN_FILE" "$tmp"; echo "time|$s|$t" >> "$tmp"; fi
    mv "$tmp" "$WPDYN_FILE"
}

_wpdyn_apply() {
    _wpdyn_init
    [[ "$(_wpdyn_get enabled)" == 1 ]] || return 0   # off → never touch the wallpaper
    local active; active="$(_wpdyn_get active)"
    [[ -n "$active" && -d "$WP_DIR/$active" ]] || return 0
    local r; r="$(_wpdyn_resolve "$WP_DIR/$active")"
    local r_sun r_day r_aft r_night; IFS='|' read -r r_sun r_day r_aft r_night <<<"$r"
    local -A P=( [sunrise]="$r_sun" [day]="$r_day" [afternoon]="$r_aft" [night]="$r_night" )
    local now best_min=-1 best="" wrap_min=-1 wrap="" s t tm p
    now=$(( 10#$(date +%H) * 60 + 10#$(date +%M) ))
    for s in "${WPDYN_SLOTS[@]}"; do
        t="$(sed -n "s#^time|$s|##p" "$WPDYN_FILE")"; [[ -z "$t" ]] && continue
        p="${P[$s]}"; [[ -z "$p" || ! -f "$p" ]] && continue
        tm=$(( 10#${t%%:*} * 60 + 10#${t##*:} ))
        (( tm <= now && tm > best_min )) && { best_min=$tm; best="$p"; }
        (( tm > wrap_min )) && { wrap_min=$tm; wrap="$p"; }
    done
    local pick="${best:-$wrap}"
    [[ -n "$pick" && -f "$pick" ]] || return 0
    [[ "$pick" == "$(cat "$HOME/.config/vendi/wallpaper" 2>/dev/null)" ]] && return 0
    _wallpaper_set "$pick"   # raw set — must NOT disable the schedule
}

cmd_wallpaper_dynamic() {
    case "${1:-status}" in
        create) shift; local g="$*"
                [[ -n "$g" ]] || { _err "usage: vendi wallpaper dynamic create <name>"; return 1; }
                mkdir -p "$WP_DIR/$g" && _ok "group created: $g" ;;
        assign) # assign <group> <slot> <image>: copy the image into the group
                # folder named after the slot so resolution matches it exactly.
                local g="$2" slot="$3" src="$4"
                [[ -n "$g" && -n "$slot" && -f "$src" ]] || { _err "usage: dynamic assign <group> <slot> <image>"; return 1; }
                mkdir -p "$WP_DIR/$g"
                rm -f "$WP_DIR/$g/$slot".*
                cp -f "$src" "$WP_DIR/$g/$slot.${src##*.}"
                systemctl --user is-active vendi-wallpaper-dynamic.timer >/dev/null 2>&1 \
                    && [[ "$(_wpdyn_get active)" == "$g" ]] && _wpdyn_apply
                _ok "$g/$slot set" ;;
        delete) shift; local g="$*"
                [[ -n "$g" && -d "$WP_DIR/$g" ]] || { _err "usage: dynamic delete <group>"; return 1; }
                rm -rf "$WP_DIR/$g"
                [[ "$(_wpdyn_get active)" == "$g" ]] && _wpdyn_setkey active ""
                _ok "group deleted: $g" ;;
        use)    shift; _wpdyn_setkey active "$*"
                systemctl --user is-active vendi-wallpaper-dynamic.timer >/dev/null 2>&1 && _wpdyn_apply
                _ok "active group: $*" ;;
        time)   shift; _wpdyn_settime "$1" "$2"
                systemctl --user is-active vendi-wallpaper-dynamic.timer >/dev/null 2>&1 && _wpdyn_apply
                _ok "$1 → $2" ;;
        on)     _wpdyn_init; _wpdyn_setkey enabled 1
                systemctl --user enable --now vendi-wallpaper-dynamic.timer 2>/dev/null || true
                _ok "dynamic wallpaper on"; _wpdyn_apply ;;
        off)    _wpdyn_setkey enabled 0
                systemctl --user disable --now vendi-wallpaper-dynamic.timer 2>/dev/null || true
                _ok "dynamic wallpaper off" ;;
        apply)  _wpdyn_apply ;;
        groups)
            # One line per group: name|sunrise|day|afternoon|night
            local d; for d in "$WP_DIR"/*/; do
                [[ -d "$d" ]] || continue
                local name; name="$(basename "$d")"
                printf '%s|%s\n' "$name" "$(_wpdyn_resolve "$d")"
            done ;;
        status)
            if systemctl --user is-active vendi-wallpaper-dynamic.timer >/dev/null 2>&1
                then echo "enabled=1"; else echo "enabled=0"; fi
            _wpdyn_init
            grep -vE '^enabled=' "$WPDYN_FILE" ;;
        *) _err "usage: vendi wallpaper dynamic <create NAME|assign GROUP SLOT IMG|delete GROUP|use GROUP|time SLOT HH:MM|on|off|apply|groups|status>"; return 1 ;;
    esac
}

# ── vendi ai ────────────────────────────────────────────────────────────────
# Natural-language assistant. Hands the request to the local vendi-ai brain
# (ollama-backed, fully local). Opt-in: needs `vendi-ai` + the ollama service.
cmd_ai() {
    if ! command -v vendi-ai >/dev/null 2>&1; then
        _err "vendi AI isn't installed yet"
        _info "it needs the vendi-ai brain + a local model (ollama)"
        return 1
    fi
    if ! systemctl is-active --quiet ollama 2>/dev/null; then
        _warn "starting the ollama service…"
        sudo systemctl start ollama 2>/dev/null || true
    fi
    if [[ $# -eq 0 ]]; then
        _info 'usage: vendi ai <request>   e.g. vendi ai "switch to gruvbox"'
        return 0
    fi
    vendi-ai "$@"
}

# ── dispatch ──────────────────────────────────────────────────────────────────
case "${1:-help}" in
    update)   cmd_update   ;;
    clean)    cmd_clean    ;;
    snapshot) cmd_snapshot ;;
    rollback) shift; cmd_rollback "$@" ;;
    theme)    shift; cmd_theme "$@" ;;
    appearance|mode) shift; cmd_appearance "$@" ;;
    wallpaper|wp) shift; cmd_wallpaper "$@" ;;
    bar)      shift; cmd_bar "$@" ;;
    display|displays|monitor|monitors) cmd_display ;;
    wifi)     cmd_wifi  ;;
    bt|bluetooth) cmd_bt ;;
    audio)    cmd_audio ;;
    power)    cmd_power ;;
    screensaver|saver|ss) shift; cmd_screensaver "$@" ;;
    ai|ask)   shift; cmd_ai "$@" ;;
    fingerprint|finger|fp) shift; cmd_fingerprint "$@" ;;
    fetch)    cmd_fetch    ;;
    info)     cmd_info     ;;
    help|--help|-h) cmd_help ;;
    *)
        _err "unknown command: ${1}"
        cmd_help
        exit 1
        ;;
esac
